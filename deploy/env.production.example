APP_NAME=Casa
APP_ENV=production
APP_KEY=                          # run: php artisan key:generate --show
APP_DEBUG=false
APP_URL=http://YOUR_DROPLET_IP    # or https://yourdomain.com once DNS is set up

LOG_CHANNEL=stack
LOG_LEVEL=error

# ── Database (fill in values printed by server-setup.sh) ─────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=casa
DB_USERNAME=casa
DB_PASSWORD=FILL_IN_FROM_SETUP

# ── File storage: DigitalOcean Spaces ────────────────────────────────────────
FILESYSTEM_DISK=s3
DO_ACCESS_KEY_ID=YOUR_DO_SPACES_KEY
DO_SECRET_ACCESS_KEY=YOUR_DO_SPACES_SECRET
DO_DEFAULT_REGION=nyc3
DO_BUCKET=casa
DO_ENDPOINT=https://nyc3.digitaloceanspaces.com
DO_URL=https://casa.nyc3.digitaloceanspaces.com

# ── Slack ─────────────────────────────────────────────────────────────────────
SLACK_PLANTS_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ── APIs ──────────────────────────────────────────────────────────────────────
PERENUAL_API_KEY=YOUR_PERENUAL_KEY
PLANTNET_API_KEY=YOUR_PLANTNET_KEY

# ── Cache / session (file is fine for a single-server personal app) ───────────
CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync
